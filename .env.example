# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000
HOSTNAME=0.0.0.0

# Voice bridge — Cloudflare Durable Object (production)
# Local: leave unset to use node server.js at same host
# Prod: wss://coldcallreps-trainer-realtime.<account>.workers.dev/api/trainer/realtime
#   or a custom route like wss://voice.coldcallreps.com/api/trainer/realtime
NEXT_PUBLIC_TRAINER_REALTIME_URL=

# Database (Postgres)
DATABASE_URL=postgresql://user:pass@localhost:5432/coldcallreps

# xAI — voice realtime + scoring + coach
XAI_API_KEY=xai-...
XAI_MODEL=grok-4.3
XAI_COACH_MODEL=grok-3-mini

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Google Maps via RapidAPI (lead discovery)
RAPIDAPI_MAPS_KEY=
RAPIDAPI_MAPS_HOST=maps-data.p.rapidapi.com

# Minutes / billing defaults
STARTER_MONTHLY_MINUTES=80
PRO_MONTHLY_MINUTES=500
REFERRAL_BONUS_MINUTES=30
