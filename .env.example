# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000
HOSTNAME=0.0.0.0

# Voice bridge — Cloudflare Durable Object (production)
# Local: leave unset to use node server.js at same host
# Prod: wss://coldcallreps-trainer-realtime.<account>.workers.dev/api/trainer/realtime
#   or a custom route like wss://voice.coldcallreps.com/api/trainer/realtime
NEXT_PUBLIC_TRAINER_REALTIME_URL=

# Database — Turso (libSQL) + local Prisma CLI
# Prisma CLI (generate / db push / studio) uses a local SQLite file:
DATABASE_URL=file:./prisma/dev.db
# App runtime connects to Turso via @prisma/adapter-libsql:
TURSO_DATABASE_URL=libsql://coldcallreps-optimald.aws-us-west-2.turso.io
# Paste your token in .env.local only — never commit it:
TURSO_AUTH_TOKEN=
# Push schema to Turso: npm run db:push:turso  (loads .env.local)

# xAI — voice realtime + scoring + coach
XAI_API_KEY=xai-...
XAI_MODEL=grok-4.3
XAI_COACH_MODEL=grok-3-mini

# OpenRouter — optional Phase 3 phone enrichment + audit (handoff). Falls back to XAI.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# UILensAI / WebEvo pro-scan (opt-in — NOT in P1→P2→P3 phone chain)
# Package: @optimald/uilensai — POST /api/prospects/[id]/webevo
# OPENROUTER_API_KEY=          # required for AI modules
# CLOUDFLARE_ACCOUNT_ID=       # CF Browser Rendering screenshots
# CLOUDFLARE_BR_API_TOKEN=     # CF Browser Rendering API token
# GOOGLE_PSI_API_KEY=          # optional Lighthouse / performance

# Trigger.dev — background pipeline (P1 scrape → P2 webscan → P3 enrich; P4/P5 frozen)
# Dev: npx trigger.dev@latest login && npm run trigger:dev
# Prod worker: npm run trigger:deploy  (uses tr_prod_… secret)
# Vercel app: set TRIGGER_SECRET_KEY=tr_prod_… (production) + TRIGGER_PROJECT_ID
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=proj_oyrhiiorgnhfhddoqvia
# Worker also needs TURSO_* / OPENROUTER_* / XAI_* / RAPIDAPI_* (synced on deploy).

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_RECRUITER_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_PACK_60_PRICE_ID=price_...
STRIPE_PACK_200_PRICE_ID=price_...
# Brand lead credits (Option B — Maps scrape + enrichment)
# Free: 100/mo · Monthly: $149 / 1,000 · Annual: $1,190 / 1,000/mo · Packs: 250/$79 · 1k/$249 · 5k/$799
STRIPE_BRAND_LEAD_MONTHLY_PRICE_ID=price_...
STRIPE_BRAND_LEAD_ANNUAL_PRICE_ID=price_...
STRIPE_LEAD_PACK_250_PRICE_ID=price_...
STRIPE_LEAD_PACK_1000_PRICE_ID=price_...
STRIPE_LEAD_PACK_5000_PRICE_ID=price_...
# Optional coupon IDs (Checkout also accepts promotion codes LAUNCH20 / BRAND50 via allow_promotion_codes)
# STRIPE_COUPON_LAUNCH20_ID=
# STRIPE_COUPON_BRAND50_ID=
# After schema: npx prisma db push && npx tsx scripts/patch-brand-lead-credits.ts (Turso)
# Connect (campaign marketplace payouts) — enable Connect in Stripe Dashboard
# (Settings → Connect → Get started). Same secret key; listen for:
#   checkout.session.completed, checkout.session.expired, account.updated
#   (+ existing subscription/invoice events)
# Optional default country for new connected accounts (ISO):
# STRIPE_CONNECT_DEFAULT_COUNTRY=US
# Local webhook: stripe listen --forward-to localhost:3000/api/billing/webhook
# Include Connect events: stripe listen --forward-to localhost:3000/api/billing/webhook \
#   --events checkout.session.completed,checkout.session.expired,account.updated,...
# After schema change: npx tsx scripts/patch-connect-payouts.ts  (Turso) + npx prisma db push

# Minutes / seats
# Free 5 · Starter $7 / 100 min · Pro $29 / 600 min · Org $60/user / 60 min/user
# Ops: update Stripe Price IDs when amounts change (esp. STRIPE_STARTER_PRICE_ID → $7)
TRIAL_MINUTES=15
STARTER_MONTHLY_MINUTES=100
PRO_MONTHLY_MINUTES=600
TEAM_MONTHLY_MINUTES=2000
# Org: $60/user/mo + 60 practice minutes / user / mo (pooled)
TEAM_MINUTES_PER_SEAT=60
TEAM_SEATS=5
# STRIPE_TEAM_PRICE_ID must be a $60/seat recurring price in Stripe Dashboard
# STRIPE_STARTER_PRICE_ID must be a $7/mo recurring price
# STRIPE_PRO_PRICE_ID must be a $29/mo recurring price
RECRUITER_MONTHLY_CREDITS=100
# Referral reward = 1 free month of Starter (both referrer + referee). Default matches STARTER_MONTHLY_MINUTES.
REFERRAL_BONUS_MINUTES=100

# Optional: Logo.dev publishable key for crisp brand logos from domain
# Free tier: https://www.logo.dev — without this we scrape icons / use Google favicons
# LOGO_DEV_PUBLISHABLE_KEY=
# NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# Cloudflare R2 (audio highlights) — S3-compatible API token
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=coldcallreps-clips
# Optional public CDN base; otherwise /api/clips/media proxies signed URLs
R2_PUBLIC_URL=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-4KW9LFF6MZ

# Platform
SUPERADMIN_EMAILS=you@example.com
TRAINER_GATE_SECRET=
TRAINER_INTERNAL_SECRET=
# Optional: Pro/Team priority coach model (defaults to XAI_MODEL)
# XAI_COACH_MODEL_PRIORITY=grok-4.3

# Optional bonus: Google Maps lead search via RapidAPI "Maps Data"
# https://rapidapi.com/alexanderxbx/api/maps-data  (host: maps-data.p.rapidapi.com)
# Endpoint used: GET /searchmaps.php?query=...&limit=...
RAPIDAPI_MAPS_KEY=
RAPIDAPI_MAPS_HOST=maps-data.p.rapidapi.com

# Resend (weekly digests + Direct Connect email)
RESEND_API_KEY=
RESEND_FROM=Cold Call Reps <reps@coldcallreps.com>
CRON_SECRET=

# Clips R2 worker (preferred over S3 API tokens)
CLIPS_WORKER_URL=https://coldcallreps-clips-r2.<account>.workers.dev
CLIPS_UPLOAD_SECRET=

# Integrations — Google Calendar (Brand meeting handoff OAuth)
# Required for /integrations → Connect Google. Without these, the card shows “Not configured”.
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Authorized redirect URI (must match exactly):
#   {NEXT_PUBLIC_APP_URL}/api/integrations/google_calendar/callback
#   e.g. http://localhost:3000/api/integrations/google_calendar/callback
# Enable Google Calendar API on the project.
# Scopes used: calendar.events, openid, email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override (defaults to {NEXT_PUBLIC_APP_URL}/api/integrations/google_calendar/callback)
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google_calendar/callback
# AES key material for encrypting OAuth tokens at rest (32+ chars recommended).
# Falls back to TRAINER_GATE_SECRET if unset.
INTEGRATION_ENCRYPTION_KEY=
# HubSpot CRM sync (ColdCallReps leads stay source of truth; HubSpot is an adapter)
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/integrations/hubspot/callback
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
# HUBSPOT_REDIRECT_URI=http://localhost:3000/api/integrations/hubspot/callback
# Close / Salesforce: coming soon. Microsoft Calendar: coming soon.

# Twilio Voice (browser click-to-call on /outbound — Cold Call desk)
# Create API Key + TwiML App at console.twilio.com
# TwiML App Voice Request URL: {NEXT_PUBLIC_APP_URL}/api/twilio/voice
#   (local: use ngrok/tunnel — Twilio cannot reach localhost)
# Brand pool DIDs use Voice URL → /api/twilio/inbound (auto-set on attach/buy).
# Campaign dials: brand local CID from BrandPhoneNumber pool. Training: TWILIO_FROM_NUMBER.
# Never use SDR personal numbers as CallerId.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_FROM_NUMBER=
# Optional: skip signature check in local tunnels
# TWILIO_SKIP_SIGNATURE=1
# Optional: expose training caller ID to browser dialer
# NEXT_PUBLIC_TWILIO_FROM_NUMBER=

# Product Hunt GraphQL (founder outbound pipeline). Without token, import uses demo launches.
# PRODUCTHUNT_API_TOKEN=

