{
  "name": "coldcallreps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "dev:next": "next dev",
    "dev:voice": "npm run dev --prefix workers/trainer-realtime",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npx tsx src/lib/trainer/integrity.test.ts",
    "db:push": "prisma db push",
    "db:push:turso": "npx tsx scripts/push-turso-schema.ts",
    "db:patch:prospect": "npx tsx scripts/patch-prospect-brand.ts",
    "db:patch:connect": "npx tsx scripts/patch-connect-payouts.ts",
    "db:patch:brand-twilio": "npx tsx scripts/patch-brand-twilio.ts",
    "db:patch:brand-phones": "npx tsx scripts/patch-brand-phones.ts",
    "db:patch:prd-gaps": "npx tsx scripts/patch-prd-gaps.ts",
    "db:patch:pipeline": "npx tsx scripts/patch-pipeline-handoff.ts",
    "db:patch:pipeline-jobs": "npx tsx scripts/patch-pipeline-jobs.ts",
    "db:patch:role-modes": "npx tsx scripts/patch-role-modes.ts",
    "db:patch:session-wrap": "npx tsx scripts/patch-trainer-session-wrap.ts",
    "db:studio": "prisma studio",
    "seed:demo-brands": "npx tsx src/lib/seed-demo-brands.ts",
    "seed:dispatchnode": "npx tsx src/lib/seed-dispatchnode.ts",
    "deploy:voice": "npm run deploy --prefix workers/trainer-realtime",
    "postinstall": "prisma generate",
    "deploy:clips": "npm run deploy --prefix workers/clips-r2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@clerk/nextjs": "^6.12.0",
    "@libsql/client": "^0.8.1",
    "@prisma/adapter-libsql": "6.19.3",
    "@prisma/client": "^6.5.0",
    "@twilio/voice-sdk": "^2.18.3",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.0",
    "lucide-react": "^1.24.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.7.0",
    "twilio": "^6.0.2",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/twilio": "^3.19.2",
    "@types/ws": "^8.18.1",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2"
  }
}
